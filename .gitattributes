# Force LF on shell scripts and Linux config files regardless of platform.
*.sh        text eol=lf
*.bash      text eol=lf
*.conf      text eol=lf
*.snippet   text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
Makefile    text eol=lf
.gitignore  text eol=lf
.editorconfig text eol=lf
.shellcheckrc text eol=lf
LICENSE     text eol=lf
*.md        text eol=lf

# Binary safety net for any driver tarballs you do choose to commit.
*.tar.gz    binary
*.tar.zst   binary
*.tar.xz    binary
*.deb       binary
*.rpm       binary
*.ppd       text eol=lf
